# Application mode: development | production
APP_ENV=development
APP_MODE=single
APP_NAME=Go License API

# HTTP port 
PORT=3000

# Admin API key for control-plane endpoints
# IMPORTANT: Change this in all environments; keep secret.
ADMIN_API_KEY=replace_me_admin

# JSON engine: std | sonic (if integrated)
JSON_ENGINE=std

# Signing key path (optional; used for signed license/JWKS features)
SIGNING_KEY_PATH=

# Worker pool configuration
WORKER_COUNT=8
WORKER_QUEUE_SIZE=500
WORKER_TIMEOUT=1500ms
WORKER_DRAIN_TIMEOUT=0

# Timeouts
VALIDATION_TIMEOUT=2s
CLIENT_TIMEOUT=3s
SHUTDOWN_TIMEOUT=30

# License validation constraints
MIN_LICENSE_KEY_LEN=8

# Audit pipeline
AUDIT_WORKER_COUNT=2
# If not provided, defaults to WORKER_COUNT*100
AUDIT_QUEUE_SIZE=
AUDIT_RETRY_COUNT=1
AUDIT_RETRY_DELAY=50ms
AUDIT_FLUSH_TIMEOUT=5

# Admin protection
# Comma-separated list of CIDRs (e.g., 10.0.0.0/8,192.168.0.0/16)
ADMIN_ALLOWED_CIDRS=
WEBHOOK_ENCRYPTION_KEY=

# Database configuration
# If DATABASE_URL is set, it takes precedence over DB_* values.
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=golicense
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Cache configuration
CACHE_L1_MAX_ENTRIES=10000

# License cache TTLs
CACHE_LICENSE_TTL_L1=5m
CACHE_LICENSE_TTL_L2=72h
CACHE_LICENSE_TTL_ACTIVE=24h
CACHE_LICENSE_TTL_NEGATIVE=60s

# Tenant cache TTLs
# 0 means non-expiring (recommended for tenant identity cache)
CACHE_TENANT_TTL=0
CACHE_TENANT_TTL_NEGATIVE=60s

# Product cache TTLs
# 0 means non-expiring (recommended for product catalog cache)
CACHE_PRODUCT_TTL=0
CACHE_PRODUCT_TTL_NEGATIVE=60s

# Redis (optional L2 cache)
REDIS_URL=

# Warmup (control-plane only; caps number of entries to prefill)
CACHE_WARMUP_LICENSE_LIMIT=1000
CACHE_WARMUP_TENANT_LIMIT=2000
CACHE_WARMUP_PRODUCT_LIMIT=1000

# Logging
LOG_ENABLED=true
LOG_OUTPUT=stdout
LOG_DIR=./logs

