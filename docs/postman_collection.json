    {
      "name": "Licenses (Runtime)",
      "item": [
        {
          "name": "POST /licenses/validate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{tenantApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"license_key\": \"{{licenseKey}}\",\n  \"product_code\": \"{{product}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/licenses/validate",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "validate"]
            }
          }
        },
        {
          "name": "POST /licenses/activate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{tenantApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"license_key\": \"{{licenseKey}}\",\n  \"product_code\": \"{{product}}\",\n  \"machine_id\": \"{{machineId}}\",\n  \"hostname\": \"{{hostname}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/licenses/activate",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "activate"]
            }
          }
        },
        {
          "name": "POST /licenses/deactivate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{tenantApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"license_key\": \"{{licenseKey}}\",\n  \"client_id\": \"{{machineId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/licenses/deactivate",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "deactivate"]
            }
          }
        },
        {
          "name": "POST /licenses/usage",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{tenantApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"license_key\": \"{{licenseKey}}\",\n  \"units\": 1,\n  \"event_id\": \"evt-123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/licenses/usage",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "usage"]
            }
          }
        },
        {
          "name": "GET /licenses/:key/signed",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{tenantApiKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/licenses/{{licenseKey}}/signed",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "{{licenseKey}}", "signed"]
            }
          }
        },
        {
          "name": "POST /licenses/signed",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{tenantApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"license_key\": \"{{licenseKey}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/licenses/signed",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "signed"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin (Control Plane)",
      "item": [
        {
          "name": "GET /admin/",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Admin-Key", "value": "{{adminKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/",
              "host": ["{{baseUrl}}"],
              "path": ["admin", ""]
            }
          }
        },
        {
          "name": "POST /admin/licenses/revoke",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Key", "value": "{{adminKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenantId}}\",\n  \"key\": \"{{licenseKey}}\",\n  \"reason\": \"compromised\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/licenses/revoke",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "licenses", "revoke"]
            }
          }
        },
        {
          "name": "PATCH /admin/tenants/:id/profile",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Key", "value": "{{adminKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Inc\",\n  \"slug\": \"acme\",\n  \"email\": \"ops@acme.io\",\n  \"company\": \"Acme Inc\",\n  \"plan\": \"pro\",\n  \"max_licenses\": 5000,\n  \"metadata\": {\"tier\": \"enterprise\"}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/tenants/{{tenantId}}/profile",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "tenants", "{{tenantId}}", "profile"]
            }
          }
        },
        {
          "name": "PATCH /admin/tenants/:id/limits",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Key", "value": "{{adminKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rps\": 200,\n  \"burst\": 400\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/tenants/{{tenantId}}/limits",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "tenants", "{{tenantId}}", "limits"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "tenantApiKey", "value": "replace_me" },
    { "key": "adminKey", "value": "replace_me_admin" },
    { "key": "licenseKey", "value": "ABC-123" },
    { "key": "product", "value": "v-plugin" },
    { "key": "machineId", "value": "machine-1" },
    { "key": "hostname", "value": "host-1" },
    { "key": "activationId", "value": "" }
  ]
